APP_ENV=production
HOST=127.0.0.1
PORT=8088
API_KEY=change-me
DATABASE_URL=postgresql+psycopg://restatify_booking:change-me@127.0.0.1:5432/restatify_booking
DEFAULT_TIMEZONE=Europe/Berlin
WORKDAY_START_HOUR=9
WORKDAY_END_HOUR=17
SLOT_STEP_MINUTES=30
