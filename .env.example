APP_ENV=production
HOST=127.0.0.1
PORT=8088
API_KEY=change-me
DATABASE_URL=postgresql+psycopg://restatify_booking:change-me@127.0.0.1:5432/restatify_booking
DEFAULT_TIMEZONE=Europe/Berlin
WORKDAY_START_HOUR=9
WORKDAY_END_HOUR=17
SLOT_STEP_MINUTES=30
MAX_WINDOW_DAYS=30
SYNC_WINDOW_DAYS=30
# Required for Google API authentication
GOOGLE_CREDENTIALS_JSON={}
# Baseline calendar IDs. API merges these with plugin sync config calendars (/v1/config/sync).
GOOGLE_CALENDAR_IDS=
# Create calendar events on successful reservation.
GOOGLE_WRITE_EVENTS_ENABLED=true
# Optional explicit target calendar id for writing; when empty, API picks first general calendar.
GOOGLE_WRITE_CALENDAR_ID=
CONFLICT_NOTIFY_ENABLED=false
CONFLICT_NOTIFY_EMAIL=
CONFLICT_NOTIFY_FROM=restatify-booking-api@localhost
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
