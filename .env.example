SYNC_WINDOW_DAYS=30
GOOGLE_CREDENTIALS_JSON={}
GOOGLE_CALENDAR_IDS=
CONFLICT_NOTIFY_ENABLED=false
CONFLICT_NOTIFY_EMAIL=
CONFLICT_NOTIFY_FROM=restatify-booking-api@localhost
