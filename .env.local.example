APP_ENV=development
HOST=0.0.0.0
PORT=8088
API_KEY=change-me-local
DATABASE_URL=postgresql+psycopg://restatify_booking:restatify_booking@db:5432/restatify_booking
DEFAULT_TIMEZONE=Europe/Berlin
WORKDAY_START_HOUR=9
WORKDAY_END_HOUR=17
SLOT_STEP_MINUTES=30
MAX_WINDOW_DAYS=30
SYNC_WINDOW_DAYS=30
SYNC_CONFIG_PATH=/app/data/sync-config.json
GOOGLE_CREDENTIALS_JSON={}
GOOGLE_CALENDAR_IDS=
CONFLICT_NOTIFY_ENABLED=true
CONFLICT_NOTIFY_EMAIL=alerts@local.test
CONFLICT_NOTIFY_FROM=restatify-booking-api@local.test
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=false
SMTP_USE_SSL=false
